# .dockerignore - Exclude files from Docker build context

# Git files
.git/
.gitignore
.gitattributes

# GitHub Actions
.github/

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/

# IDE files
.vscode/
.idea/
*.swp
*.swo
.spyderproject
.spyproject

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Testing
.pytest_cache/
.tox/
.coverage
.coverage.*
.cache
htmlcov/
.nox/
coverage.xml
*.cover
.hypothesis/

# Documentation
docs/_build/
.readthedocs.yml

# Security scan results
*.sarif
scan-report.json
tmas-results/
bandit-report.json
safety-report.json

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Backup files
*.bak
*.backup
*.old

# Docker files (avoid recursive inclusion)
Dockerfile*
.dockerignore
docker-compose*.yml

# CI/CD artifacts
.tmasignore

# Local development
.env.local
.env.development
.env.test
.env.production

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Package manager files (keep requirements.txt)
Pipfile
Pipfile.lock
poetry.lock
yarn.lock
package-lock.json